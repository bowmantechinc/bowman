# Postgres connection string — this app's database. Works with any Postgres,
# but is set up for Supabase's pooled (PgBouncer, transaction-mode) connection
# string by default: Supabase project → Settings → Database → Connection string.
POSTGRES_URL=

# Used for project file attachments (Firebase Storage).
# Firebase console → Project settings → Service accounts → Generate new private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the "private_key" value from the downloaded JSON as-is (including \n escapes).
FIREBASE_PRIVATE_KEY=
# Firebase console → Storage → the bucket name shown at the top (e.g. your-project.appspot.com).
FIREBASE_STORAGE_BUCKET=

# Used for desktop push notifications. Generate a pair with: npx web-push generate-vapid-keys
# The public key isn't secret — it's sent to the browser, so it's duplicated as NEXT_PUBLIC_*.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# A mailto: or https:// contact URL, required by the Web Push protocol.
VAPID_SUBJECT=

# Random secret used to sign session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Used to send member invitation emails. Create a free key at https://resend.com/api-keys
RESEND_API_KEY=
# Optional: defaults to "Bowman Hub <onboarding@resend.dev>" (works without a verified domain).
# Once you verify your own domain in Resend, set this to e.g. "Bowman Hub <team@yourdomain.com>".
RESEND_FROM_EMAIL=
# Optional: base URL used to build invite links. Auto-detected on Vercel; set this for custom domains.
NEXT_PUBLIC_APP_URL=
