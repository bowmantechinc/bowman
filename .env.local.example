# Postgres connection string — this app's database. Works with any Postgres,
# but is set up for Supabase's pooled (PgBouncer, transaction-mode) connection
# string by default: Supabase project → Settings → Database → Connection string.
POSTGRES_URL=

# Used for project file attachments (Supabase Storage).
# Supabase project → Settings → API.
SUPABASE_URL=
# The "service_role" secret key (not the anon/public key) — Storage writes
# happen server-side only, so this is never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Random secret used to sign session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Used to send member invitation emails. Create a free key at https://resend.com/api-keys
RESEND_API_KEY=
# Optional: defaults to "Bowman Hub <onboarding@resend.dev>" (works without a verified domain).
# Once you verify your own domain in Resend, set this to e.g. "Bowman Hub <team@yourdomain.com>".
RESEND_FROM_EMAIL=
# Optional: base URL used to build invite links. Auto-detected on Vercel; set this for custom domains.
NEXT_PUBLIC_APP_URL=
