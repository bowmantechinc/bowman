# Google service account used to read/write the Google Sheet that acts as this app's database.
# 1. Create a Google Cloud project, enable the "Google Sheets API" and "Google Drive API".
# 2. Create a Service Account, generate a JSON key.
# 3. Share your target Google Sheet with the service account's email as an Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key value from the downloaded JSON key, keeping the \n escape sequences.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"
# The ID from the sheet URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=

# Random secret used to sign session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET=
