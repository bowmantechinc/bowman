# The database (D1) and file storage (R2) are configured as bindings in
# wrangler.jsonc, not env vars — see the README for setup. R2_PUBLIC_URL is
# the one exception: it's a plain string used to build public attachment
# links, so it's a var rather than a binding.
R2_PUBLIC_URL=

# Used for desktop push notifications. Generate a pair with: npx web-push generate-vapid-keys
# The public key isn't secret — it's sent to the browser, so it's duplicated as NEXT_PUBLIC_*.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# A mailto: or https:// contact URL, required by the Web Push protocol.
VAPID_SUBJECT=

# Random secret used to sign session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Used to send member invitation and notification emails.
# Two providers are supported — pick one. EMAIL_PROVIDER selects explicitly
# ("sendgrid" or "gmail"); if unset, it auto-detects gmail when
# GOOGLE_REFRESH_TOKEN is present, otherwise sendgrid.
EMAIL_PROVIDER=

# --- Option A: SendGrid ---
# Create a key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# Must be a verified sender: https://app.sendgrid.com/settings/sender_auth
# (single-sender verification works, no domain/DNS setup required).
SENDGRID_FROM_EMAIL="Bowman Hub <you@example.com>"

# --- Option B: Gmail (send-as your Google account via the Gmail API) ---
# 1. Create an OAuth Client ID (type: Web application) in Google Cloud Console
#    with the Gmail API enabled, redirect URI: https://developers.google.com/oauthplayground
# 2. In https://developers.google.com/oauthplayground, use your own OAuth
#    credentials (gear icon), authorize scope https://www.googleapis.com/auth/gmail.send,
#    and exchange for tokens to get a refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# The Gmail address the refresh token authorizes — used as the From address.
GMAIL_SENDER_EMAIL=
# Base URL used to build invite links and push-notification URLs. Falls back to
# http://localhost:3000 if unset. In production this is set in wrangler.jsonc's
# vars instead of here; set it here too only if testing against a non-default host.
NEXT_PUBLIC_APP_URL=
